# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# ── Email (SMTP + IMAP — Google Workspace App Password) ───────────────────
# The Gmail address the agent sends FROM and monitors for replies
GMAIL_ADDRESS=support@ai.devcom.com

# App Password from: myaccount.google.com → Security → App Passwords
# (requires 2-Step Verification to be enabled on the account)
GMAIL_APP_PASSWORD=YOUR_16_CHAR_APP_PASSWORD

# SMTP settings (Gmail defaults — no need to change)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# IMAP settings (Gmail defaults — no need to change)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Gmail label applied to all compensation threads
GMAIL_COMPENSATION_LABEL=compensation

# ── Google Drive (optional — only for --watch-drive mode) ─────────────────
# Folder ID from the Drive URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID_HERE>
DRIVE_WATCH_FOLDER_ID=

# How often to check Drive for a new file (seconds)
DRIVE_POLL_INTERVAL_SECONDS=60

# ── Agent behaviour ────────────────────────────────────────────────────────
# How often to check Gmail for replies (seconds)
REPLY_POLL_INTERVAL_SECONDS=30

# Where to persist agent state across runs
STATE_FILE=state/agent_state.json

# Logging level: DEBUG | INFO | SUCCESS | WARNING | ERROR
LOG_LEVEL=INFO
